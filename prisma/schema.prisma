generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(KASIR)
  createdAt    DateTime @default(now())
  orders       Order[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  products Product[]
}

model Product {
  id            String         @id @default(uuid())
  name          String
  basePrice     Decimal        @db.Decimal(12, 2)
  unit          Unit           @default(PCS)
  isAvailable   Boolean        @default(true)
  createdAt     DateTime       @default(now())
  categoryId    Int
  orderItems    OrderItem[]
  category      Category       @relation(fields: [categoryId], references: [id])
  allowedSauces ProductSauce[]
}

model Sauce {
  id              Int            @id @default(autoincrement())
  name            String
  orderItems      OrderItem[]
  allowedProducts ProductSauce[]
}

model ProductSauce {
  productId String
  sauceId   Int
  product   Product @relation(fields: [productId], references: [id])
  sauce     Sauce   @relation(fields: [sauceId], references: [id])

  @@id([productId, sauceId])
}

model Order {
  id            String      @id @default(uuid())
  tableNumber   Int
  customerName  String
  customerCount Int         @default(1) // Jumlah orang
  status        OrderStatus @default(OPEN)
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  
  items         OrderItem[]
  payments      Payment[]

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model OrderItem {
  id          String     @id @default(uuid())
  orderId     String
  productId   String
  sauceId     Int?
  quantity    Int        @default(1)
  weight      Decimal?   @db.Decimal(10, 2)
  priceAtTime Decimal    @db.Decimal(12, 2)
  subtotal    Decimal    @db.Decimal(12, 2)
  status      ItemStatus @default(PENDING)
  isPaid      Boolean    @default(false)
  createdAt   DateTime   @default(now())
  order       Order      @relation(fields: [orderId], references: [id])
  product     Product    @relation(fields: [productId], references: [id])
  sauce       Sauce?     @relation(fields: [sauceId], references: [id])
}

model Payment {
  id         String        @id @default(uuid())
  orderId    String
  amountPaid Decimal       @db.Decimal(12, 2)
  method     PaymentMethod
  createdAt  DateTime      @default(now())
  order      Order         @relation(fields: [orderId], references: [id])
}

enum Role {
  ADMIN
  KASIR
  KITCHEN
}

enum Unit {
  KG
  PCS
}

enum OrderStatus {
  OPEN
  PAID
  CANCELLED
}

enum ItemStatus {
  PENDING
  COOKING
  SERVED
}

enum PaymentMethod {
  CASH
  QRIS
  DEBIT
}
